{
  "name": "adzan-challenge-website",
  "version": "1.0.0",
  "description": "Adzan Challenge Website - Gamification platform for adzan practice",
  "main": "dist/backend/server.js",
  "scripts": {
    "dev:backend": "ts-node src/backend/server.ts",
    "dev:frontend": "vite",
    "dev": "ts-node src/backend/server.ts",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build": "vite build",
    "start": "node dist/backend/server.js",
    "preview": "vite preview",
    "test": "jest --testPathPattern=src/frontend",
    "test:watch": "jest --watch --testPathPattern=src/frontend",
    "test:backend": "jest --testPathPattern=src/backend",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "adzan",
    "gamification",
    "challenge"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^2.2.2",
    "clsx": "^2.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^5.4.19"
  }
}
